@startuml
class Document {
  +Guid Id
  +string Name
  +string Content
  +DateTimeOffset CreatedAt
  +DateTimeOffset? UpdatedAt
  +Rename(name: string)
}

class DocumentRepository {
  +GetById(id: Guid): Document
  +Save(document: Document)
  +Delete(id: Guid)
}

