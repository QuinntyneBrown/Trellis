{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=App_Data/trellis.db"
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:4200" ]
  },
  "PlantUml": {
    "JavaExecutablePath": "java",
    "JarPath": "Vendor/plantuml/plantuml.jar",
    "IncludePath": "Vendor/c4-plantuml",
    "RenderTimeoutSeconds": 10,
    "MaxConcurrentRenders": 4
  }
}
